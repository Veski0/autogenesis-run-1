# Copy to .env and fill in. All values are read by bootstrap.js at startup.

# --- Option A: OpenAI ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# MODEL=gpt-4o-mini

# --- Option B: Ollama (local, no API key needed) ---
# Use a TOOL-CAPABLE model (e.g. qwen2.5, llama3.1, mistral-nemo, command-r).
# Non-tool models will run but the agent cannot call its self-edit tool, so it
# will only emit text and get the generic "Continue" nudge forever.
OPENAI_API_KEY=
OPENAI_BASE_URL=http://localhost:11434/v1
MODEL=glm-5.2:cloud

# Optional safety cap on loop iterations (default: unlimited)
# MAX_STEPS=500
